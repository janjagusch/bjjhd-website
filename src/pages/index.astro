---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrainingSchedule from '../components/TrainingSchedule.astro';
import CampaiSignup from '../components/CampaiSignup.astro';
import { campai, contact, pricing } from '../config';
import { withBase } from '../utils/withBase';
---

<BaseLayout>
  <Hero />

  <!-- 1 + 2. Training: Gi + days -->
  <section id="training" class="section">
    <div class="container">
      <h2>Training</h2>
      <p class="section__intro">
        We train Brazilian Jiu-Jitsu in the Gi (the uniform worn in far-eastern
        martial arts). Beginners are welcome any time, minimum age 16. For your
        <a href="#trial">trial session</a> you can come in regular sportswear –
        if you message us beforehand, we can probably lend you a Gi. Please also
        read our <a href={withBase('/rules')}>rules</a>.
      </p>
      <p class="info-box" role="note">
        <span class="info-box__icon" aria-hidden="true">★</span>
        <span>Our training starts on <strong>August 7th</strong>.</span>
      </p>
      <div style="margin-top: var(--space-xl);">
        <TrainingSchedule />
      </div>
    </div>
  </section>

  <!-- 3. Location -->
  <section id="location" class="section section--alt">
    <div class="container">
      <h2>Where we train</h2>
      <p class="section__intro">
        We train in the facilities of TSG 78 Heidelberg.
      </p>
      <div class="card" style="margin-top: var(--space-lg); max-width: 60ch;">
        <address class="contact__address">
          {contact.venue}<br />
          {contact.venueStreet}<br />
          {contact.venueZip} {contact.venueCity}
        </address>
        <p style="margin-top: var(--space-md);">
          <a
            href={contact.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open route on Google Maps (opens in a new tab)"
            >Open route on Google Maps ↗</a
          >
        </p>
      </div>
      <ul class="venue-info">
        <li>
          If you come by car, you can park at the
          <a
            href="https://maps.app.goo.gl/tiPE2gZkjqbkHdeo9"
            target="_blank"
            rel="noopener noreferrer"
            >Tiergarten swimming pool parking ↗</a
          >.
        </li>
        <li>Using the shower costs 50 cents (coin-operated).</li>
      </ul>
    </div>
  </section>

  <!-- 4. Free trial class -->
  <section id="trial" class="section">
    <div class="container">
      <h2>Book a free trial class</h2>
      <p class="section__intro">
        Visitors and people wanting a trial session are very welcome – your
        first class is <strong>free</strong>. Register below and we’ll get back
        to you.
      </p>
      <div style="margin-top: var(--space-xl);">
        <CampaiSignup src={campai.trialFormSrc} />
      </div>
    </div>
  </section>

  <!-- 5. Prices -->
  <section id="prices" class="section section--alt">
    <div class="container">
      <h2>Prices</h2>
      <div class="grid grid--3" style="margin-top: var(--space-xl);">
        {
          pricing.map((item) => (
            <div class="card price">
              <h3 class="price__name">{item.name}</h3>
              <p class="price__amount">{item.price}</p>
              {item.note && <p class="price__note">{item.note}</p>}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 6. Become a member -->
  <section id="signup" class="section">
    <div class="container">
      <h2>Ready to join?</h2>
      <p class="section__intro">
        Loved your trial and want to train with us regularly? Become a member
        and join the club.
      </p>
      <div style="margin-top: var(--space-xl);">
        <a href={withBase('/signup')} class="btn btn--primary"
          >Become a member</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .info-box {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    max-width: 60ch;
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(181, 86, 43, 0.07);
    border: 1px solid rgba(181, 86, 43, 0.25);
    border-radius: var(--radius-md);
    color: var(--color-text);
  }
  .info-box__icon {
    flex: 0 0 auto;
    color: var(--color-warm);
    font-size: var(--fs-600);
    line-height: 1;
  }

  .price {
    text-align: center;
  }
  .price__name {
    font-size: var(--fs-500);
  }
  .price__amount {
    color: var(--color-accent);
    font-size: var(--fs-700);
    font-weight: 800;
    margin-top: var(--space-xs);
  }
  .price__note {
    color: var(--color-text-muted);
    font-size: var(--fs-300);
    margin-top: var(--space-xs);
  }

  .contact__address {
    font-style: normal;
    line-height: var(--lh-base);
    color: var(--color-text);
  }

  .venue-info {
    margin: var(--space-lg) 0 0;
    padding-left: 1.25rem;
    max-width: 60ch;
    display: grid;
    gap: var(--space-xs);
    color: var(--color-text-muted);
  }
</style>
