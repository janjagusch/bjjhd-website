---
import BaseLayout from '../layouts/BaseLayout.astro';
import { guidelines } from '../config';
---

<BaseLayout
  title="Rules & Guidelines"
  description="Our training and mat rules for a safe and fair environment."
>
  <section class="section">
    <div class="container">
      <h1>Rules &amp; Guidelines</h1>
      <p class="section__intro">
        These rules keep our mat safe, fair and respectful for everyone. Please
        read them – they apply to everybody, whether you’re a beginner or
        advanced.
      </p>

      <div class="guidelines">
        {
          guidelines.map((group) => (
            <section class="guidelines__group" aria-labelledby={`g-${group.category}`}>
              <h2 id={`g-${group.category}`} class="guidelines__category">
                {group.category}
              </h2>
              <ul class="guidelines__list">
                {group.items.map((item) => (
                  <li class="guidelines__item">
                    <h3 class="guidelines__title">{item.title}</h3>
                    <p class="guidelines__text">{item.text}</p>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .guidelines {
    margin-top: var(--space-2xl);
    display: grid;
    gap: var(--space-2xl);
  }

  .guidelines__category {
    font-size: var(--fs-700);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .guidelines__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 720px) {
    .guidelines__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .guidelines__item {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .guidelines__title {
    font-size: var(--fs-500);
    margin-bottom: var(--space-xs);
  }

  .guidelines__text {
    color: var(--color-text-muted);
  }
</style>
