---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { club } from '../config';
import { withBase } from '../utils/withBase';
import { routes, locales, defaultLocale, ui } from '../i18n';
import type { Locale, RouteKey } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  /**
   * If this page exists in multiple languages, pass its route key so the
   * layout can emit canonical + hreflang alternate links. Omit for
   * single-language pages (e.g. the German-only legal pages).
   */
  routeKey?: RouteKey;
  /** Set to true to keep the page out of search indexes (e.g. confirmation pages). */
  noindex?: boolean;
}

const {
  title = `${club.name} – Brazilian Jiu-Jitsu`,
  description = club.tagline,
  lang = defaultLocale,
  routeKey,
  noindex = false,
} = Astro.props;

// Map the page language to an Open Graph locale.
const ogLocale = lang === 'de' ? 'de_DE' : 'en_US';

// Build absolute URLs for canonical + hreflang. `Astro.site` has no base path,
// so withBase() supplies it. Falls back to the current URL if `site` is unset.
function absolute(path: string): string {
  return new URL(withBase(path), Astro.site ?? Astro.url).href;
}

const canonical = routeKey
  ? absolute(routes[routeKey][lang])
  : Astro.url.href;

// hreflang alternates: one per locale, plus x-default pointing at the default.
const alternates = routeKey
  ? locales.map((l) => ({ hreflang: l, href: absolute(routes[routeKey][l]) }))
  : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }
    {
      routeKey && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={absolute(routes[routeKey][defaultLocale])}
        />
      )
    }

    <!-- Fonts: Newsreader (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..600&family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- Open Graph (no tracking, just nice previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <a class="skip-link" href="#main">{ui[lang].skip}</a>
    <Header lang={lang} routeKey={routeKey} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
