---
import Hero from '../Hero.astro';
import TrainingSchedule from '../TrainingSchedule.astro';
import CampaiSignup from '../CampaiSignup.astro';
import StructuredData from '../StructuredData.astro';
import { campai, contact, pricing } from '../../config';
import { withBase } from '../../utils/withBase';
import { ui, routes, homeAnchor, defaultLocale } from '../../i18n';
import type { Locale } from '../../i18n';

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = ui[lang];
---

<StructuredData />
<Hero lang={lang} />

<!-- 0. What is BJJ? (intro + link to the beginner's guide) -->
<section id="what" class="section section--alt">
  <div class="container">
    <h2>{t.whatHeading}</h2>
    {
      lang === 'de' ? (
        <p class="section__intro">
          Brazilian Jiu-Jitsu (BJJ) ist eine Kampfsportart, die sich auf
          Bodenkampf, Hebel und Würger konzentriert. Mit Technik, Timing und
          Hebelwirkung statt roher Kraft kannst du auch größere und stärkere
          Partner kontrollieren. BJJ ist für alle da – egal ob du fit werden,
          dich verteidigen lernen oder einfach Teil einer Gemeinschaft sein
          möchtest. Du brauchst keine Vorerfahrung.
        </p>
      ) : (
        <p class="section__intro">
          Brazilian Jiu-Jitsu (BJJ) is a martial art focused on ground
          fighting, joint locks and chokes. Using technique, timing and leverage
          instead of raw strength, you can control bigger and stronger partners.
          BJJ is for everyone – whether you want to get fit, learn to defend
          yourself, or simply be part of a community. No prior experience needed.
        </p>
      )
    }
    <p style="margin-top: var(--space-md);">
      <a href={withBase(routes.beginners[lang])}>{t.whatLink}</a>
    </p>
  </div>
</section>

<!-- 1 + 2. Training: Gi + days -->
<section id="training" class="section">
  <div class="container">
    <h2>{t.trainingHeading}</h2>
    {
      lang === 'de' ? (
        <p class="section__intro">
          Wir trainieren Brazilian Jiu-Jitsu im Gi. Anfänger sind jederzeit
          willkommen, Mindestalter 16. Für dein
          <a href={homeAnchor(lang, 'trial')}>Probetraining</a> kannst du in
          normaler Sportkleidung kommen – wenn du dich vorher meldest, können wir
          dir wahrscheinlich einen Gi leihen. Bitte lies auch unsere
          <a href={withBase(routes.rules[lang])}>Regeln</a>.
        </p>
      ) : (
        <p class="section__intro">
          We train Brazilian Jiu-Jitsu in the Gi. Beginners are welcome any
          time, minimum age 16. For your
          <a href={homeAnchor(lang, 'trial')}>trial session</a> you can come in
          regular sportswear – if you message us beforehand, we can probably lend
          you a Gi. Please also read our
          <a href={withBase(routes.rules[lang])}>rules</a>.
        </p>
      )
    }
    <p class="info-box" role="note">
      <span class="info-box__icon" aria-hidden="true">★</span>
      <span set:html={`${t.startPrefix}<strong>${t.startDate}</strong>${t.startSuffix}`} />
    </p>
    <div style="margin-top: var(--space-xl);">
      <TrainingSchedule lang={lang} />
    </div>
  </div>
</section>

<!-- 3. Location -->
<section id="location" class="section section--alt">
  <div class="container">
    <h2>{t.locationHeading}</h2>
    <p class="section__intro">{t.locationIntro}</p>
    <div class="card" style="margin-top: var(--space-lg); max-width: 60ch;">
      <address class="contact__address">
        {contact.venue}<br />
        {contact.venueStreet}<br />
        {contact.venueZip} {contact.venueCity}
      </address>
      <p style="margin-top: var(--space-md);">
        <a
          href={contact.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.mapsAria}>{t.mapsLink}</a
        >
      </p>
    </div>
    <ul class="venue-info">
      {
        lang === 'de' ? (
          <li>
            Wenn du mit dem Auto kommst, kannst du am
            <a
              href="https://maps.app.goo.gl/tiPE2gZkjqbkHdeo9"
              target="_blank"
              rel="noopener noreferrer">
              Parkplatz des Tiergartenbads ↗
            </a>{' '}
            parken.
          </li>
        ) : (
          <li>
            If you come by car, you can park at the
            <a
              href="https://maps.app.goo.gl/tiPE2gZkjqbkHdeo9"
              target="_blank"
              rel="noopener noreferrer">
              Tiergarten swimming pool parking ↗
            </a>
            .
          </li>
        )
      }
      <li>{t.showerInfo}</li>
    </ul>
  </div>
</section>

<!-- 4. Free trial class -->
<section id="trial" class="section">
  <div class="container">
    <h2>{t.trialHeading}</h2>
    {
      lang === 'de' ? (
        <p class="section__intro">
          Besucher und alle, die ein Probetraining möchten, sind herzlich
          willkommen – deine erste Stunde ist <strong>kostenlos</strong>. Melde
          dich unten an und wir kommen auf dich zurück.
        </p>
      ) : (
        <p class="section__intro">
          Visitors and people wanting a trial session are very welcome – your
          first class is <strong>free</strong>. Register below and we’ll get back
          to you.
        </p>
      )
    }
    <div style="margin-top: var(--space-xl);">
      <CampaiSignup src={campai.trialFormSrc} />
    </div>
  </div>
</section>

<!-- 5. Prices -->
<section id="prices" class="section section--alt">
  <div class="container">
    <h2>{t.pricesHeading}</h2>
    <div class="grid grid--3" style="margin-top: var(--space-xl);">
      {
        pricing.map((item) => (
          <div class="card price">
            <h3 class="price__name">{item.name[lang]}</h3>
            <p class="price__amount">
              {item.price} <span class="price__suffix">{t.priceSuffix}</span>
            </p>
            {item.note && <p class="price__note">{item.note[lang]}</p>}
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- 6. Become a member -->
<section id="signup" class="section">
  <div class="container">
    <h2>{t.joinHeading}</h2>
    <p class="section__intro">{t.joinIntro}</p>
    <div style="margin-top: var(--space-xl);">
      <a href={withBase(routes.signup[lang])} class="btn btn--primary"
        >{t.ctaMember}</a
      >
    </div>
  </div>
</section>

<style>
  .info-box {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    max-width: 60ch;
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(181, 86, 43, 0.07);
    border: 1px solid rgba(181, 86, 43, 0.25);
    border-radius: var(--radius-md);
    color: var(--color-text);
  }
  .info-box__icon {
    flex: 0 0 auto;
    color: var(--color-warm);
    font-size: var(--fs-600);
    line-height: 1;
  }

  .price {
    text-align: center;
  }
  .price__name {
    font-size: var(--fs-500);
  }
  .price__amount {
    color: var(--color-accent);
    font-size: var(--fs-700);
    font-weight: 800;
    margin-top: var(--space-xs);
  }
  .price__suffix {
    color: var(--color-text-muted);
    font-size: var(--fs-400);
    font-weight: 500;
  }
  .price__note {
    color: var(--color-text-muted);
    font-size: var(--fs-300);
    margin-top: var(--space-xs);
  }

  .contact__address {
    font-style: normal;
    line-height: var(--lh-base);
    color: var(--color-text);
  }

  .venue-info {
    margin: var(--space-lg) 0 0;
    padding-left: 1.25rem;
    max-width: 60ch;
    display: grid;
    gap: var(--space-xs);
    color: var(--color-text-muted);
  }
</style>
