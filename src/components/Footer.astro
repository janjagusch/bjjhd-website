---
import { club, contact } from '../config';
import { withBase } from '../utils/withBase';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="brand__name">{club.name}</span>
    </div>

    <nav class="site-footer__col" aria-label="Contact">
      <h2 class="site-footer__heading">Contact</h2>
      <address>
        {contact.legalEntity}<br />
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </address>
    </nav>

    <nav class="site-footer__col" aria-label="Legal">
      <h2 class="site-footer__heading">Legal</h2>
      <ul class="site-footer__links">
        <li><a href={withBase('/impressum')}>Impressum</a></li>
        <li><a href={withBase('/datenschutz')}>Datenschutz</a></li>
      </ul>
    </nav>
  </div>

  <div class="container site-footer__bottom">
    <p>&copy; {year} {contact.legalEntity}</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-2xl) var(--space-lg);
    color: var(--color-text-muted);
  }

  .site-footer__inner {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .site-footer__inner {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .brand__name {
    color: var(--color-heading);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--fs-600);
  }

  .site-footer__brand p {
    margin-top: var(--space-xs);
    max-width: 40ch;
  }

  .site-footer__social {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .site-footer__heading {
    color: var(--color-heading);
    font-size: var(--fs-400);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }

  address {
    font-style: normal;
    line-height: var(--lh-base);
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-xs);
  }

  .site-footer__bottom {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: var(--fs-300);
  }
</style>
