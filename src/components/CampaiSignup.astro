---
import { campai } from '../config';
---

<div class="campai">
  <p class="campai__intro">
    Want to become a member? Just fill in the form below.
  </p>

  <div class="campai__frame">
    <iframe
      src={campai.iframeSrc}
      data-campai-id
      title="Membership application (provided by Campai)"
      loading="lazy"
    ></iframe>
  </div>

  <p class="campai__hint">
    Note: This form is provided by Campai. By submitting it, your details are
    processed to handle your request. Learn more in our
    <a href="/datenschutz">privacy policy</a>.
  </p>
</div>

<script is:inline src={campai.scriptSrc}></script>

<style>
  .campai {
    max-width: 760px;
    margin-inline: auto;
  }

  .campai__intro {
    font-size: var(--fs-500);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .campai__frame {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: var(--space-sm);
    overflow: hidden;
  }

  .campai__frame iframe {
    display: block;
    width: 100%;
    min-height: 720px;
    border: 0;
    border-radius: var(--radius-sm);
    background-color: #ffffff;
  }

  .campai__hint {
    margin-top: var(--space-md);
    font-size: var(--fs-300);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .campai__frame iframe {
      min-height: 860px;
    }
  }
</style>
